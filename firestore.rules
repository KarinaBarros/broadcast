rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isAuth() && data.userId == request.auth.uid;
    }

    function isOwnerCreate() {
      return isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /connections/{id} {

      allow create: if isOwnerCreate();

      allow read: if isAuth();

      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /contacts/{id} {

      allow create: if isOwnerCreate();

      allow read: if isAuth();

      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /messages/{id} {

      allow create: if isOwnerCreate();

      allow read: if isAuth();

      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}